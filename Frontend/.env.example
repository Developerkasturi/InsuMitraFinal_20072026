# ─────────────────────────────────────────────────────────────────────────────
# InsuMitra Frontend — Environment Variables
# Copy this file to .env and fill in real values.
# All variables MUST start with VITE_ to be exposed to browser code.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Full URL to the backend API (your Render deployment URL)
# Include the /api/v1 path suffix
VITE_API_URL=https://insumitra-backend.onrender.com/api/v1

# WebSocket server URL (same host as backend, no path suffix)
VITE_WS_URL=https://insumitra-backend.onrender.com
