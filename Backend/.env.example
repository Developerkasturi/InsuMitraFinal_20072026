# ─────────────────────────────────────────────────────────────────────────────
# InsuMitra Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT is auto-assigned by Render — omit it or leave blank
PORT=3000
API_PREFIX=api/v1

# ── Frontend URL (set to your Vercel deployment URL) ──────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string. Include the database name before query parameters.
DATABASE_URL=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/insumitra?retryWrites=true&w=majority

# ── Redis ─────────────────────────────────────────────────────────────────────
# Upstash Redis URL (recommended for serverless-friendly Redis)
# Format: rediss://:PASSWORD@HOST:PORT  (rediss = TLS)
REDIS_URL=rediss://:your-redis-password@your-host.upstash.io:6380

# If using host/port instead of a URL:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_to_another_strong_random_secret
JWT_REFRESH_EXPIRES_IN=30d
JWT_SUPERADMIN_SECRET=change_me_to_superadmin_strong_secret

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=supabase   # supabase | s3

# Supabase storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=insumitra-documents

# AWS S3 (only needed if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=insumitra-documents

# ── Email — Brevo (formerly Sendinblue) ───────────────────────────────────────
BREVO_API_KEY=your-brevo-api-key
SENDER_EMAIL=noreply@insumitra.com
SENDER_NAME=InsuMitra

# ── WhatsApp ──────────────────────────────────────────────────────────────────
WHATSAPP_API_URL=https://api.whatsapp.example.com
WHATSAPP_API_KEY=your-whatsapp-api-key

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ── Rate limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
