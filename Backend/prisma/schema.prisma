  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("employee_profiles")
}

model EmployeeTask {
  id               String     @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String     @map("tenant_id") @db.ObjectId
  createdById String     @map("created_by_id") @db.ObjectId
  assignedToId String     @map("assigned_to_id") @db.ObjectId
  title            String
  description      String?
  status           TaskStatus   @default(PENDING)
  priority         TaskPriority @default(MEDIUM)
  dueDate          DateTime?    @map("due_date")
  completedAt      DateTime?    @map("completed_at")
  relatedContactId String?      @map("related_contact_id") @db.ObjectId
  relatedPolicyId  String?      @map("related_policy_id")
  deletedAt        DateTime?    @map("deleted_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt      @map("updated_at")

  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy        User       @relation("TaskCreator",  fields: [createdById],  references: [id])
  assignedTo       User       @relation("TaskAssignee", fields: [assignedToId], references: [id])

  @@index([tenantId])
  @@index([tenantId, assignedToId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@map("employee_tasks")
}

model EmployeeDailyLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String   @map("tenant_id") @db.ObjectId
  userId String   @map("user_id") @db.ObjectId
  logDate     DateTime @map("log_date")
  checkIn     DateTime? @map("check_in")
  checkOut    DateTime? @map("check_out")
  notes       String?
  leadsWorked Int      @default(0) @map("leads_worked")
  callsMade   Int      @default(0) @map("calls_made")
  visitsCompleted   Int      @default(0) @map("visits_completed")
  premiumCollected  Float    @default(0) @map("premium_collected")
  nextDayPlan       String?  @map("next_day_plan")
  isEditedByAdmin   Boolean  @default(false) @map("is_edited_by_admin")
  adminRemarks      String?  @map("admin_remarks")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt    @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, logDate])
  @@index([tenantId])
  @@index([tenantId, userId, logDate])
  @@map("employee_daily_logs")
}

// ═════════════════════════════════════════════════════════════════════════════
// COMMISSIONS
// ═════════════════════════════════════════════════════════════════════════════

model CommissionYear {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String   @map("tenant_id") @db.ObjectId
  year        Int
  name        String   // e.g. "FY 2024-25"
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt     @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  commissions Commission[]

  @@unique([tenantId, year])
  @@index([tenantId])
  @@map("commission_years")
}

model Commission {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String   @map("tenant_id") @db.ObjectId
  policyId String   @map("policy_id") @db.ObjectId
  commissionYearId String   @map("commission_year_id") @db.ObjectId
  beneficiaryId    String   @map("beneficiary_id") @db.ObjectId
  
  // Base
  basePremium          Float? @map("base_premium")
  baseCommissionRate   Float? @map("base_commission_rate")
  baseCommissionAmount Float? @map("base_commission_amount")
  
  // Addon
  addonPremium          Float? @map("addon_premium")
  addonCommissionRate   Float? @map("addon_commission_rate")
  addonCommissionAmount Float? @map("addon_commission_amount")

  // Other types
  deductibleRate        Float? @map("deductible_rate")
  deductibleAmount      Float? @map("deductible_amount")
  monthlyGridRate       Float? @map("monthly_grid_rate")
  monthlyGridAmount     Float? @map("monthly_grid_amount")
  otherRate             Float? @map("other_rate")
  otherAmount           Float? @map("other_amount")
  renewalRate           Float? @map("renewal_rate")
  renewalAmount         Float? @map("renewal_amount")

  // Yearly splits
  year1Commission       Float? @map("year1_commission")
  year2Commission       Float? @map("year2_commission")
  year3Commission       Float? @map("year3_commission")
  year4Commission       Float? @map("year4_commission")
  year5Commission       Float? @map("year5_commission")

  amount           Float
  rate             Float  @map("rate")
  isPaid           Boolean  @default(false)           @map("is_paid")
  paidAt           DateTime? @map("paid_at")
  notes            String?
  createdAt        DateTime @default(now())           @map("created_at")
  updatedAt        DateTime @updatedAt                @map("updated_at")

  tenant         Tenant         @relation(fields: [tenantId],         references: [id], onDelete: Cascade)
  policy         Policy         @relation(fields: [policyId],         references: [id])
  commissionYear CommissionYear @relation(fields: [commissionYearId], references: [id])
  beneficiary    User           @relation(fields: [beneficiaryId],    references: [id])

  @@index([tenantId])
  @@index([tenantId, beneficiaryId])
  @@index([tenantId, policyId])
  @@map("commissions")
}

// ═════════════════════════════════════════════════════════════════════════════
// WHATSAPP MARKETING
// ═════════════════════════════════════════════════════════════════════════════

model WhatsappTemplate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String   @map("tenant_id") @db.ObjectId
  name        String
  body        String   // Supports {{variable}} placeholders
  category    String   // PROMOTIONAL | TRANSACTIONAL | REMINDER
  language    String   @default("en")
  variables   String[] @default([])
  isActive    Boolean  @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaigns   WhatsappCampaign[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("whatsapp_templates")
}

model WhatsappCampaign {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String         @map("tenant_id") @db.ObjectId
  templateId String         @map("template_id") @db.ObjectId
  name          String
  status        CampaignStatus @default(DRAFT)
  scheduledAt   DateTime?      @map("scheduled_at")
  startedAt     DateTime?      @map("started_at")
  completedAt   DateTime?      @map("completed_at")
  targetFilters Json           @default("{}") @map("target_filters") // audience filter criteria
  totalCount    Int            @default(0) @map("total_count")
  sentCount     Int            @default(0) @map("sent_count")
  failedCount   Int            @default(0) @map("failed_count")
  costPerMsg    Float?       @map("cost_per_msg")
  totalCost     Float?       @map("total_cost")
  deletedAt     DateTime?      @map("deleted_at")
  createdAt     DateTime       @default(now())      @map("created_at")
  updatedAt     DateTime       @updatedAt           @map("updated_at")

  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template      WhatsappTemplate  @relation(fields: [templateId], references: [id])
  logs          WhatsappLog[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("whatsapp_campaigns")
}

model WhatsappLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId String   @map("campaign_id") @db.ObjectId
  phone       String
  status      String   // QUEUED | SENT | DELIVERED | READ | FAILED
  error       String?
  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime @default(now()) @map("created_at")

  campaign    WhatsappCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, status])
  @@map("whatsapp_logs")
}

/// Per-tenant WhatsApp wallet balance
model WhatsappWallet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String   @unique @map("tenant_id") @db.ObjectId
  balance   Float  @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions  WalletTransaction[]

  @@map("whatsapp_wallets")
}

model WalletTransaction {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  walletId String       @map("wallet_id") @db.ObjectId
  type        WalletTxType
  amount      Float
  balanceAfter Float @map("balance_after")
  description String?
  referenceId String?  @map("reference_id")
  createdAt   DateTime @default(now()) @map("created_at")

  wallet      WhatsappWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@map("wallet_transactions")
}

// ═════════════════════════════════════════════════════════════════════════════
// CALENDAR EVENTS
// ═════════════════════════════════════════════════════════════════════════════

model CalendarEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String   @map("tenant_id") @db.ObjectId
  contactId String?  @map("contact_id") @db.ObjectId
  title       String
  description String?
  eventType   EventType @map("event_type")
  startAt     DateTime  @map("start_at")
  endAt       DateTime? @map("end_at")
  isAllDay    Boolean   @default(false) @map("is_all_day")
  isAutomatic Boolean   @default(false) @map("is_automatic")
  relatedId String?   @map("related_id") @db.ObjectId  // policyId | leadId (polymorphic)
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now())      @map("created_at")
  updatedAt   DateTime  @updatedAt           @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact     Contact? @relation(fields: [contactId], references: [id])

  @@index([tenantId])
  @@index([tenantId, startAt])
  @@index([tenantId, deletedAt])
  @@map("calendar_events")
}

// ═════════════════════════════════════════════════════════════════════════════
// SUBSCRIPTIONS & BILLING
// ═════════════════════════════════════════════════════════════════════════════

model Subscription {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String             @map("tenant_id") @db.ObjectId
  planId String             @map("plan_id") @db.ObjectId
  status      SubscriptionStatus @default(TRIAL)
  startDate   DateTime           @map("start_date")
  endDate     DateTime           @map("end_date")
  trialEnd    DateTime?          @map("trial_end")
  cancelledAt DateTime?          @map("cancelled_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt      @map("updated_at")

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan        SubscriptionPlan   @relation(fields: [planId], references: [id])
  payments    SubscriptionPayment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("subscriptions")
}

model SubscriptionPayment {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  subscriptionId String   @map("subscription_id") @db.ObjectId
  amount         Float
  currency       String   @default("INR")
  status         String   // PENDING | PAID | FAILED | REFUNDED
  gateway        String?  // RAZORPAY | STRIPE | MANUAL
  gatewayId      String?  @map("gateway_id")
  paidAt         DateTime? @map("paid_at")
  invoiceUrl     String?   @map("invoice_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt     @map("updated_at")

  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("subscription_payments")
}

// ═════════════════════════════════════════════════════════════════════════════
// DOCUMENTS
// ═════════════════════════════════════════════════════════════════════════════

model Document {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String       @map("tenant_id") @db.ObjectId
  contactId String?      @map("contact_id") @db.ObjectId
  policyId String?      @map("policy_id") @db.ObjectId
  claimId String?      @map("claim_id") @db.ObjectId
  type        DocumentType @default(OTHER)
  name        String
  storageKey  String?      @map("storage_key")  // S3 key or Supabase path
  url         String        // S3 / Supabase URL
  mimeType    String?      @map("mime_type")
  sizeBytes   Int?         @map("size_bytes")
  uploadedById String?     @map("uploaded_by_id") @db.ObjectId
  isVerified  Boolean      @default(false) @map("is_verified")
  expiresAt   DateTime?    @map("expires_at")
  deletedAt   DateTime?    @map("deleted_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt     @map("updated_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact     Contact?  @relation(fields: [contactId], references: [id])
  policy      Policy?   @relation(fields: [policyId],  references: [id])
  claim       Claim?    @relation(fields: [claimId],   references: [id])

  @@index([tenantId])
  @@index([tenantId, contactId])
  @@index([tenantId, policyId])
  @@index([tenantId, deletedAt])
  @@map("documents")
}

// ═════════════════════════════════════════════════════════════════════════════
// NOTIFICATIONS
// ═════════════════════════════════════════════════════════════════════════════

model Notification {
  id         String           @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String           @map("tenant_id") @db.ObjectId
  userId String           @map("user_id") @db.ObjectId
  type       NotificationType
  title      String
  body       String
  data       Json             @default("{}")
  isRead     Boolean          @default(false) @map("is_read")
  readAt     DateTime?        @map("read_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([tenantId, userId, isRead])
  @@map("notifications")
}

// ═════════════════════════════════════════════════════════════════════════════
// ACTIVITY LOGS
// ═════════════════════════════════════════════════════════════════════════════

model ActivityLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String   @map("tenant_id") @db.ObjectId
  userId String?  @map("user_id") @db.ObjectId
  contactId String?  @map("contact_id") @db.ObjectId
  entityType  String   @map("entity_type")  // Contact | Policy | Claim | Lead
  entityId String   @map("entity_id") @db.ObjectId
  action      String   // CREATE | UPDATE | DELETE | VIEW | STAGE_CHANGE | IMPORT
  description String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact     Contact? @relation(fields: [contactId], references: [id])

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, contactId])
  @@map("activity_logs")
}

// ═════════════════════════════════════════════════════════════════════════════
// FEATURE FEEDBACK
// ═════════════════════════════════════════════════════════════════════════════

model FeatureFeedback {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId  String   @map("tenant_id") @db.ObjectId
  userId    String   @map("user_id") @db.ObjectId
  message   String
  rating    Int?
  createdAt DateTime @default(now()) @map("created_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("feature_feedbacks")
}

// ═════════════════════════════════════════════════════════════════════════════
// DELETION REQUESTS
// ═════════════════════════════════════════════════════════════════════════════

model DeletionRequest {
  id          String                @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String                @map("tenant_id") @db.ObjectId
  requestedBy String                @map("requested_by") @db.ObjectId
  entityType  String                @map("entity_type")
  entityId    String                @map("entity_id") @db.ObjectId
  reason      String?
  status      DeletionRequestStatus @default(PENDING)
  resolvedBy  String?               @map("resolved_by") @db.ObjectId
  resolvedAt  DateTime?             @map("resolved_at")
  createdAt   DateTime              @default(now()) @map("created_at")

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("deletion_requests")
}
